# ── Database ──
DATABASE_URL="postgresql://user:password@localhost:5432/greenmark_rms?schema=public"

# ── Auth ──
JWT_SECRET="change-this-to-a-secure-random-string"
JWT_EXPIRES_IN="15m"

# ── Server ──
PORT=3000
NODE_ENV=development
CORS_ORIGIN="http://localhost:5173"

# ── Chapa Payment Gateway ──
CHAPA_SECRET_KEY="CHASECK_TEST-your-chapa-secret-key-here"
CHAPA_WEBHOOK_URL="https://your-domain.com/api/v1/payments/webhook"
CHAPA_RETURN_URL="https://your-domain.com/payment/success"
